{
  "appId": "org.bdrailway.kotchandpur",
  "productName": "BD Railway Kotchandpur",
  "directories": {
    "buildResources": "resources"
  },
  "files": [
    "assets/**/*",
    "build/**/*",
    "capacitor.config.*",
    "app/**/*"
  ],
  "publish": null,
  "nsis": {
    "allowElevation": true,
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "win": {
    "target": "nsis",
    "icon": "assets/appIcon.ico"
  },
  "linux": {
    "target": "deb",
    "category": "Utility"
  },
  "mac": {
    "category": "public.app-category.travel",
    "target": "dmg"
  }
}